---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { Star, MapPin } from 'lucide-react';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  { key: 'morning', market: 'talatSao' },
  { key: 'night', market: 'nightMarket' },
];
---

<section class="py-24 bg-zinc-900 text-white border-y border-zinc-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">{t('reviews.title')}</h2>
      <div class="w-24 h-1 bg-mekong-blue mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {cards.map(({ key, market }) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 hover:border-mekong-blue/40 transition-colors">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-xl font-bold">{t(`reviews.${key}.name`)}</h3>
          </div>

          <div class="flex items-center gap-3 mb-6">
            <Star className="w-6 h-6 fill-current text-amber-400" />
            <span class="text-2xl font-bold">{t(`markets.${market}.rating`)}</span>
          </div>

          <div class="flex flex-wrap gap-2 mb-8">
            {t(`reviews.${key}.tags`).map((tag: string) => (
              <span class="px-3 py-1.5 rounded-full text-xs font-medium bg-mekong-blue/15 text-mekong-blue border border-mekong-blue/30">
                {tag}
              </span>
            ))}
          </div>

          <a
            href={t(`reviews.${key}.mapUrl`) as string}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-3 bg-mekong-blue hover:bg-mekong-blue/90 text-white font-medium rounded-xl transition-colors"
          >
            <MapPin className="w-4 h-4 mr-2" />
            {t(`reviews.${key}.mapLabel`)}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

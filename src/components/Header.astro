---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import LanguagePicker from './LanguagePicker';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="fixed w-full top-0 z-40 bg-white/80 backdrop-blur-md border-b border-zinc-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <div class="flex-shrink-0 flex items-center">
        <a href={lang === 'lo' ? '/' : `/${lang}/`} class="text-xl font-bold text-mekong-blue tracking-tight">
          {t('nav.title')}
        </a>
      </div>
      
      <nav class="hidden md:flex space-x-6">
        <a href="#market-core" class="text-zinc-600 hover:text-mekong-blue px-2 py-2 text-sm font-medium transition-colors">{t('nav.compare')}</a>
        <a href="#history" class="text-zinc-600 hover:text-mekong-blue px-2 py-2 text-sm font-medium transition-colors">{t('nav.history')}</a>
        <a href="#itinerary" class="text-zinc-600 hover:text-mekong-blue px-2 py-2 text-sm font-medium transition-colors">{t('nav.itinerary')}</a>
        <a href="#culture" class="text-zinc-600 hover:text-mekong-blue px-2 py-2 text-sm font-medium transition-colors">{t('nav.culture')}</a>
        <a href="#map" class="text-zinc-600 hover:text-mekong-blue px-2 py-2 text-sm font-medium transition-colors">{t('nav.map')}</a>
      </nav>

      <div class="flex items-center">
        <LanguagePicker client:load currentLang={lang} />
      </div>
    </div>
  </div>
</header>

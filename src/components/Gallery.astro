---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import GalleryViewer from './GalleryViewer';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const images = [
  ...[1, 2, 3].map((n) => `/gallery/talat-sao-${n}.jpg`),
  ...[1, 2, 3].map((n) => `/gallery/night-market-${n}.jpg`),
  ...Array.from({ length: 10 }, (_, i) => `/gallery/market-culture-${i + 1}.jpg`),
];
---

<GalleryViewer
  client:load
  images={images}
  tTitle={t('gallery.title')}
  tMapLink={t('gallery.mapLink')}
/>

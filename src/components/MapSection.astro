---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { Bus, Car, Footprints } from 'lucide-react';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="map" class="py-24 bg-zinc-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 mb-4">{t('map.title')}</h2>
      <div class="w-24 h-1 bg-mekong-blue mx-auto rounded-full"></div>
    </div>

    <div class="grid lg:grid-cols-3 gap-12 items-start">
      <div class="lg:col-span-1 space-y-8">
        <h3 class="text-2xl font-bold text-zinc-900 mb-6">{t('map.transport')}</h3>
        
        <div class="flex gap-4 items-start">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm shrink-0 border border-zinc-100">
            <Bus className="w-6 h-6 text-mekong-blue" />
          </div>
          <div>
            <p class="text-zinc-700 leading-relaxed">{t('map.tuktuk')}</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm shrink-0 border border-zinc-100">
            <Car className="w-6 h-6 text-mekong-blue" />
          </div>
          <div>
            <p class="text-zinc-700 leading-relaxed">{t('map.loca')}</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm shrink-0 border border-zinc-100">
            <Footprints className="w-6 h-6 text-mekong-blue" />
          </div>
          <div>
            <p class="text-zinc-700 leading-relaxed">{t('map.walk')}</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="w-full h-[400px] md:h-[500px] rounded-3xl overflow-hidden shadow-xl border-4 border-white">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3795.176226531386!2d102.61397069678955!3d17.970536300000003!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3124687ed455e1df%3A0x24af4d39ae4445b0!2z5LiH6LGh5Yev5peL6Zeo!5e0!3m2!1szh-CN!2sus!4v1784771502551!5m2!1szh-CN!2sus" 
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="strict-origin-when-cross-origin">
          </iframe>
        </div>
      </div>
    </div>
  </div>
</section>

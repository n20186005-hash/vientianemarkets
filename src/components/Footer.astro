---
import { getLangFromUrl, useTranslations } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const morningMap = 'https://maps.google.com/?cid=15367807096000210240';
const nightMap = 'https://maps.google.com/?cid=14960580795493471890';
const tourism = 'https://www.tourismlaos.org/';
const mict = 'https://mict.gov.la/';
const privacyHref = `/${lang}/privacy`;
const termsHref = `/${lang}/terms`;
---

<footer class="bg-slate-900 text-slate-400">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Column 1: About & Disclaimer -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-mekong-blue rounded-lg flex items-center justify-center text-white font-bold">V</div>
          <span class="font-bold text-white">{t('footer.aboutTitle')}</span>
        </div>
        <p class="text-sm leading-relaxed mb-3">{t('footer.aboutText1')}</p>
        <p class="text-sm leading-relaxed">{t('footer.aboutText2')}</p>
      </div>

      <!-- Column 2: Official & Reference Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t('footer.resTitle')}</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={tourism} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{t('footer.resTourism')}</a>
          </li>
          <li>
            <a href={mict} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{t('footer.resMict')}</a>
          </li>
          <li>
            <a href={morningMap} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{t('footer.resMorningMap')}</a>
          </li>
          <li>
            <a href={nightMap} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">{t('footer.resNightMap')}</a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Privacy & Terms -->
      <div>
        <h3 class="text-white font-semibold mb-4">{t('footer.legalTitle')}</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={privacyHref} class="hover:text-white transition-colors">{t('footer.privacy')}</a>
          </li>
          <li>
            <a href={termsHref} class="hover:text-white transition-colors">{t('footer.terms')}</a>
          </li>
          <li>
            <a href="#cookie-settings" class="hover:text-white transition-colors">{t('footer.cookie')}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-center text-sm">
      {t('footer.copyright')}
    </div>
  </div>
</footer>

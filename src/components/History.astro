---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import { History as HistoryIcon, Shirt, Gem, Fish, Sunset } from 'lucide-react';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  { key: 'evolution', Icon: HistoryIcon, tint: 'bg-blue-50 text-mekong-blue' },
  { key: 'textile', Icon: Shirt, tint: 'bg-amber-50 text-amber-600' },
  { key: 'etiquette', Icon: Gem, tint: 'bg-rose-50 text-rose-600' },
  { key: 'naga', Icon: Fish, tint: 'bg-cyan-50 text-cyan-700' },
  { key: 'sunset', Icon: Sunset, tint: 'bg-orange-50 text-orange-600' },
];
---

<section id="history" class="py-24 bg-zinc-50 border-y border-zinc-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-zinc-900 mb-4">{t('history.title')}</h2>
      <div class="w-24 h-1 bg-mekong-blue mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {cards.map(({ key, Icon, tint }) => (
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-zinc-100 hover:shadow-md transition-shadow">
          <div class={`w-14 h-14 ${tint} rounded-xl flex items-center justify-center mb-6`}>
            <Icon className="w-7 h-7" />
          </div>
          <h3 class="text-xl font-bold text-zinc-900 mb-4">{t(`history.${key}.title`)}</h3>
          <p class="text-zinc-600 leading-relaxed">
            {t(`history.${key}.desc`)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import MarketCore from '../components/MarketCore.astro';
import History from '../components/History.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import MapSection from '../components/MapSection.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n/ui';

const t = useTranslations('lo');
---

<Layout title={t('hero.title') as string} description={t('hero.subtitle') as string}>
  <Header />
  <main>
    <Hero />
    <MarketCore />
    <History />
    <Gallery />
    <Reviews />
    <MapSection />
  </main>
  <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLangFromUrl, useTranslations, languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('footer.termsTitle') as string} description={t('footer.termsTitle') as string}>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold text-zinc-900 mb-6">{t('footer.termsTitle')}</h1>
    <p class="text-zinc-600 leading-relaxed">{t('footer.termsBody')}</p>
  </main>
  <Footer />
</Layout>
